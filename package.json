{
  "name": "@heyintech/sdkr",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "repository": "heyintech/sdkr",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsdown && node ./scripts/build-nuxt-dts.mjs",
    "prepack": "pnpm build",
    "dev": "pnpm dev:prepare && pnpm --dir packages/nuxt/playground dev",
    "dev:build": "pnpm dev:prepare && pnpm --dir packages/nuxt/playground build",
    "dev:prepare": "pnpm build && pnpm --dir packages/nuxt/playground exec nuxt prepare",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "tsc --project packages/nuxt/tsconfig.json --noEmit && pnpm --dir packages/nuxt/playground exec vue-tsc --noEmit"
  },
  "devDependencies": {
    "@nuxt/devtools": "catalog:",
    "@nuxt/eslint-config": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@types/node": "catalog:",
    "changelogen": "catalog:",
    "eslint": "catalog:",
    "nuxt": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "bumpp": "catalog:",
    "vue-tsc": "catalog:"
  }
}
